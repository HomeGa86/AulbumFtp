<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 2. 内部嵌套一个垂直的 LinearLayout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <EditText
        android:id="@+id/et_ftp_host"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/ftp_name" />

    <EditText
        android:id="@+id/et_ftp_port"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/ftp_port"
        android:inputType="number" />

    <EditText
        android:id="@+id/et_ftp_user"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/user_name" />

    <EditText
        android:id="@+id/et_ftp_pass"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/password"
        android:inputType="textPassword" />

    <EditText
        android:id="@+id/et_ftp_base_path"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/base_path" />

    <CheckBox
        android:id="@+id/cb_is_sftp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/is_sftp"
        android:checked="true" />

    <EditText
        android:id="@+id/et_backup_ftp_host"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/backup_ftp_name" />

    <EditText
        android:id="@+id/et_backup_ftp_port"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/backup_ftp_port"
        android:inputType="number" />

</LinearLayout>

</ScrollView>