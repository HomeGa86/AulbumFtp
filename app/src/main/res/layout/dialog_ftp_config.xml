<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <EditText
        android:id="@+id/et_ftp_host"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/ftp_name" />

    <EditText
        android:id="@+id/et_ftp_port"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/ftp_port"
        android:inputType="number" />

    <EditText
        android:id="@+id/et_ftp_user"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/user_name" />

    <EditText
        android:id="@+id/et_ftp_pass"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/password"
        android:inputType="textPassword" />

    <EditText
        android:id="@+id/et_ftp_base_path"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/base_path" />

    <CheckBox
        android:id="@+id/cb_passive_mode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/passiv_mode"
        android:checked="true" />

</LinearLayout>